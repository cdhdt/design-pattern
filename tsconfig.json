{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,

    "rootDir": "src"
  },
  "include": ["src/**/*.ts"]
}
